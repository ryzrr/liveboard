{
  "name": "liveboard-sdk",
  "version": "0.1.0",
  "description": "LiveBoard SDK — zero-config API observability for Express, Fastify, and more",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": ["api", "observability", "monitoring", "express", "fastify", "liveboard"],
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.0.0",
    "@types/node": "^20.0.0",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "fastify": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true }
  }
}
